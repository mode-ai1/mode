# MØDE — Hermes Agent secrets (EXAMPLE)
#
# Copy to ~/.hermes/.env and fill in real values. NEVER commit the real .env.
# Secrets belong here ONLY; non-secret settings go in config.yaml.
# Safest way to set these: `hermes config set <key> <value>` (routes secrets here
# automatically). Key names marked (verify) — confirm against the Hermes docs.

# ──────────────────────────────────────────────────────────────────────────────
# Model — Nemotron via NVIDIA NIM (primary). Required.
# ──────────────────────────────────────────────────────────────────────────────
NVIDIA_API_KEY=
# NVIDIA_BASE_URL=                 # only if using a local NIM or a custom endpoint

# ──────────────────────────────────────────────────────────────────────────────
# Fallback provider — required only if you configured fallback_providers in config.yaml.
# ──────────────────────────────────────────────────────────────────────────────
# NOUS_PORTAL_API_KEY=             # (verify) Portal fallback to Nemotron
# ANTHROPIC_API_KEY=               # optional second fallback, if you keep one

# ──────────────────────────────────────────────────────────────────────────────
# Integrations — uncomment as you wire each surface. None required to boot the tutor.
# ──────────────────────────────────────────────────────────────────────────────
# STRIPE_API_KEY=                  # payments via the Stripe MCP server (earn/spend)
# Messaging gateway (parent reports) — set only the channels you enable:
# TELEGRAM_BOT_TOKEN=
# SLACK_BOT_TOKEN=

# ──────────────────────────────────────────────────────────────────────────────
# Memory provider — only if you set memory.provider in config.yaml (else built-in files).
# ──────────────────────────────────────────────────────────────────────────────
# HONCHO_API_KEY=                  # (verify) example pluggable memory provider
